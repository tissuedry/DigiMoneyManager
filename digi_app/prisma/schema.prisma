generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int                  @id @default(autoincrement())
  nama               String
  email              String               @unique
  passwordHash       String               @map("password_hash")
  role               String               @map("role")
  approvals          Approval[]
  auditTrails        AuditTrail[]
  notifications      Notification[]
  pengajuanAnggaran  PengajuanAnggaran[]
  reimbursements     Reimbursement[]
  proyek             UserProyek[]

  @@index([role])
  @@map("users")
}

model Proyek {
  id                 Int                  @id @default(autoincrement())
  nama               String
  deskripsi          String?
  status             String
  tanggalMulai       DateTime             @map("tanggal_mulai")
  tanggalSelesai     DateTime?            @map("tanggal_selesai")
  budget             Budget?
  pengajuanAnggaran  PengajuanAnggaran[]
  reimbursements     Reimbursement[]
  users              UserProyek[]

  @@index([status])
  @@index([tanggalMulai])
  @@map("proyek")
}

model UserProyek {
  id       Int      @id @default(autoincrement())
  proyekId Int      @map("proyek_id")
  userId   Int      @map("user_id")
  role     String   @map("role")
  divisi   String?  @map("divisi")
  joinedAt DateTime @default(now()) @map("joined_at")
  proyek   Proyek   @relation(fields: [proyekId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, proyekId])
  @@index([userId, role])
  @@map("user_proyek")
}

model Budget {
  id                 Int            @id @default(autoincrement())
  proyekId           Int            @unique @map("proyek_id")
  rabTotal           Decimal        @map("rab_total") @db.Decimal(15, 2)
  totalPengeluaran   Decimal        @default(0) @map("total_pengeluaran") @db.Decimal(15, 2)
  totalReimbursement Decimal        @default(0) @map("total_reimbursement") @db.Decimal(15, 2)
  sisaBudget         Decimal        @map("sisa_budget") @db.Decimal(15, 2)
  proyek             Proyek         @relation(fields: [proyekId], references: [id], onDelete: Cascade)
  mainAnggaran       MainAnggaran[]

  @@map("budget")
}

model MainAnggaran {
  id              Int           @id @default(autoincrement())
  budgetId        Int           @map("budget_id")
  namaMain        String        @map("nama_main")
  nominalAlokasi  Decimal       @map("nominal_alokasi") @db.Decimal(15, 2)
  nominalTerpakai Decimal       @default(0) @map("nominal_terpakai") @db.Decimal(15, 2)
  budget          Budget        @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  subAnggaran     SubAnggaran[]

  @@index([budgetId])
  @@map("main_anggaran")
}

model SubAnggaran {
  id              Int                  @id @default(autoincrement())
  mainAnggaranId  Int                  @map("main_anggaran_id")
  namaSub         String               @map("nama_sub")
  nominalAlokasi  Decimal              @map("nominal_alokasi") @db.Decimal(15, 2)
  nominalTerpakai Decimal              @default(0) @map("nominal_terpakai") @db.Decimal(15, 2)
  keterangan      KeteranganAnggaran[]
  mainAnggaran    MainAnggaran         @relation(fields: [mainAnggaranId], references: [id], onDelete: Cascade)

  @@index([mainAnggaranId])
  @@map("sub_anggaran")
}

model KeteranganAnggaran {
  id               Int             @id @default(autoincrement())
  subAnggaranId    Int             @map("sub_anggaran_id")
  keterangan       String
  nominalAlokasi   Decimal         @map("nominal_alokasi") @db.Decimal(15, 2)
  nominalRealisasi Decimal         @default(0) @map("nominal_realisasi") @db.Decimal(15, 2)
  subAnggaran      SubAnggaran     @relation(fields: [subAnggaranId], references: [id], onDelete: Cascade)
  reimbursements   Reimbursement[]

  @@index([subAnggaranId])
  @@map("keterangan_anggaran")
}

model Reimbursement {
  id                   Int                @id @default(autoincrement())
  userId               Int                @map("user_id")
  proyekId             Int                @map("proyek_id")
  keteranganAnggaranId Int                @map("keterangan_anggaran_id")
  nominal              Decimal            @db.Decimal(15, 2)
  urlStruk             String             @map("url_struk")
  ocrData              Json               @map("ocr_data")
  fraudFlag            Boolean            @default(false) @map("fraud_flag")
  status               String
  approvals            Approval[]
  jurnalAkuntansi      JurnalAkuntansi[]
  keteranganAnggaran   KeteranganAnggaran @relation(fields: [keteranganAnggaranId], references: [id])
  proyek               Proyek             @relation(fields: [proyekId], references: [id], onDelete: Cascade)
  user                 User               @relation(fields: [userId], references: [id])

  @@index([keteranganAnggaranId])
  @@index([status, proyekId])
  @@index([userId])
  @@index([proyekId])
  @@map("reimbursement")
}

model Approval {
  id              Int           @id @default(autoincrement())
  reimbursementId Int           @map("reimbursement_id")
  approverId      Int           @map("approver_id")
  level           String
  status          String
  catatan         String?
  timestamp       DateTime      @default(now())
  approver        User          @relation(fields: [approverId], references: [id])
  reimbursement   Reimbursement @relation(fields: [reimbursementId], references: [id], onDelete: Cascade)

  @@index([reimbursementId])
  @@index([approverId])
  @@index([level, status, timestamp])
  @@map("approval")
}

model JurnalAkuntansi {
  id              Int             @id @default(autoincrement())
  reimbursementId Int             @map("reimbursement_id")
  noAkunKredit    String          @map("no_akun_kredit")
  noAkunDebit     String          @map("no_akun_debit")
  nominal         Decimal         @db.Decimal(15, 2)
  keterangan      String?
  akunDebit       ChartOfAccounts @relation("DebitAccount", fields: [noAkunDebit], references: [id])
  akunKredit      ChartOfAccounts @relation("KreditAccount", fields: [noAkunKredit], references: [id])
  reimbursement   Reimbursement   @relation(fields: [reimbursementId], references: [id], onDelete: Cascade)

  @@index([reimbursementId])
  @@index([noAkunDebit])
  @@index([noAkunKredit])
  @@map("jurnal_akuntansi")
}

model ChartOfAccounts {
  id           String            @id
  nomorAkun    Int               @map("nomor_akun")
  namaAkun     String            @map("nama_akun")
  tipe         String
  standar      String
  jurnalDebit  JurnalAkuntansi[] @relation("DebitAccount")
  jurnalKredit JurnalAkuntansi[] @relation("KreditAccount")

  @@index([nomorAkun])
  @@map("chart_of_accounts")
}

model AuditTrail {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  aksi      String
  detail    String
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@index([timestamp])
  @@map("audit_trail")
}

model PengajuanAnggaran {
  id          Int                     @id @default(autoincrement())
  proyekId    Int                     @map("proyek_id")
  pengajuId   Int                     @map("pengaju_id")
  judul       String
  deskripsi   String?
  status      String                  @default("PENDING")
  catatan     String?
  createdAt   DateTime                @default(now()) @map("created_at")
  processedAt DateTime?               @map("diproses_pada")
  pengaju     User                    @relation(fields: [pengajuId], references: [id])
  proyek      Proyek                  @relation(fields: [proyekId], references: [id], onDelete: Cascade)
  items       PengajuanAnggaranItem[]

  @@index([proyekId, status])
  @@index([status, createdAt])
  @@map("pengajuan_anggaran")
}

model PengajuanAnggaranItem {
  id             Int               @id @default(autoincrement())
  pengajuanId    Int               @map("pengajuan_id")
  tipe           String
  aksi           String
  targetId       Int?              @map("target_id")
  parentId       Int?              @map("parent_id")
  nama           String?
  nominalAlokasi Decimal?          @map("nominal_alokasi") @db.Decimal(15, 2)
  pengajuan      PengajuanAnggaran @relation(fields: [pengajuanId], references: [id], onDelete: Cascade)

  @@index([pengajuanId])
  @@map("pengajuan_anggaran_item")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tipe      String
  pesan     String
  dibaca    Boolean  @default(false)
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dibaca, timestamp])
  @@map("notifications")
}


model MasterMain {
  id        Int         @id @default(autoincrement())
  nama      String
  MasterSub MasterSub[]

  @@map("master_main")
}

model MasterSub {
  id               Int                @id @default(autoincrement())
  mainId           Int                @map("main_id")
  nama             String
  MasterKeterangan MasterKeterangan[]
  master_main      MasterMain         @relation(fields: [mainId], references: [id], onDelete: Cascade)

  @@map("master_sub")
}

model MasterKeterangan {
  id         Int       @id @default(autoincrement())
  subId      Int       @map("sub_id")
  nama       String
  master_sub MasterSub @relation(fields: [subId], references: [id], onDelete: Cascade)

  @@map("master_keterangan")
}
